---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  areaServed?: string[];
}

const {
  title,
  description,
  canonical,
  // Default: full service area. City pages override this with that city listed
  // first, so the page's schema emphasizes local relevance for that specific page.
  areaServed = [
    "Santa Clarita", "Valencia", "Granada Hills", "Porter Ranch", "Northridge",
    "Encino", "Sherman Oaks", "Woodland Hills", "Calabasas", "Burbank",
    "Glendale", "Agoura Hills",
  ],
} = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site);

// LocalBusiness schema — service-area business, no public street address by design.
const businessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
  name: "GK Swimming Pools",
  image: "https://www.gkswimmingpools.com/images/logo-white.png",
  url: "https://www.gkswimmingpools.com",
  telephone: "+18188048204",
  email: "admin@GKswimmingpools.com",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressRegion: "CA",
    addressCountry: "US",
  },
  areaServed: areaServed.map((city) => ({ "@type": "City", name: city })),
  // AggregateRating: weighted average across Google (10 reviews, 5.0) and
  // Yelp (3 reviews, 4.0) = 62 total stars / 13 reviews = 4.8.
  // Update these two numbers whenever review counts change meaningfully —
  // never estimate, always pull the real current numbers from both platforms.
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "13",
    bestRating: "5",
    worstRating: "1",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "07:00",
      closes: "18:00",
    },
  ],
  sameAs: [
    "https://www.yelp.com/biz/gk-pool-maintenance-santa-clarita-4",
    "https://share.google/yhUdlVxS35lH8ZsIS",
  ],
};
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="OS_h77ISBhBeBhClgRZf0jAvgkQQiJKcIogQuYtNgwg" />

    <!-- Google tag (gtag.js) — one shared loader for both GA4 and Google Ads.
         is:inline is intentional here: Google's own instructions require this
         literally inline in <head> on every page, and gtag/dataLayer need to
         be true globals (not scoped to a bundled ES module) so other scripts
         on the page, like the contact form, can call them. -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7QDN080XF0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7QDN080XF0');   // Google Analytics 4
      gtag('config', 'AW-17308243497'); // Google Ads

      // Shared conversion helper — takes the specific label for each action,
      // avoids the name collision from pasting Google's two separate snippets
      // verbatim (both were named the same thing, which would silently break
      // one of them). event_timeout is a safety net: if the tracking beacon
      // is slow or blocked, navigation still happens after 2s rather than
      // the click appearing to do nothing.
      function gtagReportConversion(conversionLabel, url) {
        var callback = function () {
          if (typeof(url) != 'undefined') {
            window.location = url;
          }
        };
        gtag('event', 'conversion', {
          'send_to': 'AW-17308243497/' + conversionLabel,
          'value': 1.0,
          'currency': 'USD',
          'event_callback': callback,
          'event_timeout': 2000,
        });
        return false;
      }

      // Auto-attach call-conversion tracking to every phone link on every
      // page (nav, footer, hero buttons, mobile menu, etc.) — no need to
      // edit each one by hand across the site.
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('a[href^="tel:"]').forEach(function (link) {
          link.addEventListener('click', function () {
            gtagReportConversion('4AchCLKf08wcEKmsm71A');
          });
        });
      });
    </script>

    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="GK Swimming Pools" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  </head>
  <body>

    <nav class="nav">
      <div class="nav__inner">
        <a href="/" class="nav__logo">
          <img src="/images/logo-white.png" alt="GK Swimming Pools" class="nav__logo-img" />
        </a>

        <ul class="nav__links">
          <li><a href="/">Home</a></li>
          <li class="nav__dropdown">
            <a href="#">Services</a>
            <div class="nav__dropdown-menu">
              <ul class="nav__dropdown-menu-inner">
                <li><a href="/services/pool-maintenance">Pool Maintenance</a></li>
                <li><a href="/services/pool-inspections">Pool Inspections</a></li>
                <li><a href="/services/pool-repairs">Pool Repairs</a></li>
                <li><a href="/services/pool-remodeling">Pool Remodeling</a></li>
                <li><a href="/services/jacuzzi-service">Jacuzzi Service</a></li>
                <li><a href="/services/commercial-pool-services">Commercial Pool Service</a></li>
              </ul>
            </div>
          </li>
          <li><a href="/our-story">Our Story</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>

        <a href="tel:8188048204" class="nav__phone">(818) 804-8204</a>

        <button class="nav__burger" id="nav-burger" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- MOBILE MENU PANEL -->
      <div class="mobile-menu" id="mobile-menu">
        <ul class="mobile-menu__links">
          <li><a href="/">Home</a></li>
          <li><a href="/services/pool-maintenance">Pool Maintenance</a></li>
          <li><a href="/services/pool-inspections">Pool Inspections</a></li>
          <li><a href="/services/pool-repairs">Pool Repairs</a></li>
          <li><a href="/services/pool-remodeling">Pool Remodeling</a></li>
          <li><a href="/services/jacuzzi-service">Jacuzzi Service</a></li>
          <li><a href="/services/commercial-pool-services">Commercial Pool Service</a></li>
          <li><a href="/our-story">Our Story</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
        <a href="tel:8188048204" class="mobile-menu__phone">(818) 804-8204</a>
      </div>
    </nav>

    <script>
      const burger = document.getElementById('nav-burger');
      const mobileMenu = document.getElementById('mobile-menu');

      burger?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.toggle('is-open');
        burger.classList.toggle('is-open', isOpen);
        burger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        document.body.classList.toggle('menu-open', isOpen);
      });

      // Close the menu when a link inside it is tapped
      mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          burger?.classList.remove('is-open');
          burger?.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('menu-open');
        });
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer__grid">
          <div>
            <img src="/images/logo-white.png" alt="GK Swimming Pools" class="footer__logo" />
            <p class="footer__tagline">Three generations of honest pool service across Los Angeles. Fair pricing, proactive care, and a commitment to treating every pool like our own.</p>
            <a href="tel:8188048204" class="footer__phone">(818) 804-8204</a>
          </div>
          <div>
            <h4>Services</h4>
            <ul>
              <li><a href="/services/pool-maintenance">Pool Maintenance</a></li>
              <li><a href="/services/pool-inspections">Pool Inspections</a></li>
              <li><a href="/services/pool-repairs">Pool Repairs</a></li>
              <li><a href="/services/pool-remodeling">Pool Remodeling</a></li>
              <li><a href="/services/jacuzzi-service">Jacuzzi Service</a></li>
              <li><a href="/services/commercial-pool-services">Commercial Pool Service</a></li>
            </ul>
          </div>
          <div>
            <h4>Company</h4>
            <ul>
              <li><a href="/our-story">Our Story</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/blog">Blog</a></li>
            </ul>
            <h4 style="margin-top: var(--space-6);">Service Areas</h4>
            <ul>
              <li><a href="/locations/pool-service-santa-clarita">Santa Clarita</a></li>
              <li><a href="/locations/pool-service-valencia">Valencia</a></li>
              <li><a href="/locations/pool-service-granada-hills">Granada Hills</a></li>
              <li><a href="/locations/pool-service-porter-ranch">Porter Ranch</a></li>
              <li><a href="/locations/pool-service-northridge">Northridge</a></li>
              <li><a href="/locations/pool-service-encino">Encino</a></li>
              <li><a href="/locations/pool-service-sherman-oaks">Sherman Oaks</a></li>
              <li><a href="/locations/pool-service-woodland-hills">Woodland Hills</a></li>
              <li><a href="/locations/pool-service-calabasas">Calabasas</a></li>
              <li><a href="/locations/pool-service-burbank">Burbank</a></li>
              <li><a href="/locations/pool-service-glendale">Glendale</a></li>
              <li><a href="/locations/pool-service-agoura-hills">Agoura Hills</a></li>
            </ul>
          </div>
        </div>
        <div class="footer__bottom">
          <p>&copy; {new Date().getFullYear()} GK Swimming Pools. All rights reserved. | Santa Clarita, CA | (818) 804-8204</p>
        </div>
      </div>
    </footer>

  </body>
</html>
