---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Pool inspections in Santa Clarita | GK Swimming Pools"
  description="Structural, plumbing, and equipment pool inspections across Santa Clarita and LA, with detailed reports. Trusted swimming pool contractor. (818) 804-8204."
>

  <section class="hero">
    <div class="hero__bg">
      <img src="/images/services/pool-inspections-hero.webp" alt="Pool inspection in progress at a Los Angeles area home" fetchpriority="high" decoding="async" />
    </div>
    <div class="container hero__inner">
      <h1 class="hero__h1">Pool Inspections · Los Angeles</h1>
      <p class="hero__offer">#1 Leak Detection Company<br><em>in Los Angeles for 20+ Years</em></p>
      <p class="hero__sub">Comprehensive pool and spa inspection services, from structural integrity to safety compliance, with detailed reports after every visit.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Price</a>
        <a href="tel:8188048204" class="btn btn--outline">Schedule an Inspection</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 760px;">
        <span class="eyebrow">Premier Pool & Spa Inspection</span>
        <p class="lead" style="margin-bottom: 1.5rem;">
          GK Swimming Pools specializes in comprehensive pool and spa inspection services for pools all across Los Angeles. Whether you're buying a home, maintaining your current pool, or need a safety assessment, our certified inspection team delivers detailed, reliable reports.
        </p>
        <p style="color: var(--color-muted);">
          We proudly serve homeowners throughout West LA, Encino, Sherman Oaks, Brentwood, Pacific Palisades, Bel Air, Malibu, Marina Del Rey, and Beverly Hills. With over 20 years of experience, our licensed and insured inspectors bring unmatched expertise to every job.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What's Included</span>
        <h2>Our Pool Inspections Include</h2>
      </div>
      <ul class="service-list">
        <li>
          <strong>Structural Inspection</strong>
          Thorough examination of the pool or spa shell for cracks, shifting, or signs of structural wear that may compromise safety or lead to leaks.
        </li>
        <li>
          <strong>Non-Invasive Plumbing Inspection</strong>
          Using advanced, non-invasive techniques to inspect underground pipes and plumbing lines for signs of leaks, blockages, or damage, without disrupting your yard or deck.
        </li>
        <li>
          <strong>Pool & Spa Equipment Inspection</strong>
          Assessment of all major equipment: pumps, filters, heaters, and control systems, to ensure they're operating efficiently, safely, and within manufacturer specifications.
        </li>
        <li>
          <strong>Circulation and Filtration System Check</strong>
          Evaluating water flow, filter performance, and circulation systems to confirm they're keeping your pool clean and balanced effectively.
        </li>
        <li>
          <strong>Tile, Coping, and Surface Inspection</strong>
          Detailed review of tile, grout, coping, and plaster surfaces for cracks, erosion, or damage that may affect aesthetics and integrity.
        </li>
        <li>
          <strong>Deck and Surrounding Area Inspection</strong>
          Assessing the deck and surrounding pool area for surface wear, trip hazards, drainage issues, or cracks that could lead to future problems.
        </li>
        <li>
          <strong>Skimmer and Drain Inspection</strong>
          Checking the condition and function of skimmers, drains, and returns to ensure proper water intake, flow, and safety compliance.
        </li>
        <li>
          <strong>Safety Feature Assessment</strong>
          Reviewing safety elements such as fencing, gates, alarms, and covers to ensure your pool meets current safety standards.
        </li>
        <li>
          <strong>Spa-Specific System Inspection</strong>
          For spa owners, we evaluate jet performance, temperature control, and additional equipment for optimal functionality and comfort.
        </li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why GK</span>
        <h2>Why Choose GK Swimming Pools?</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">01</div>
          <h3>Experienced & Reliable</h3>
          <p>With years of experience, we offer professional and reliable service tailored specifically to the needs of your residential pool or spa.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">02</div>
          <h3>Comprehensive Reports</h3>
          <p>After each inspection, we provide detailed reports with recommendations for any necessary repairs or maintenance.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">03</div>
          <h3>Transparent Pricing</h3>
          <p>We offer competitive and upfront pricing with no hidden fees for repairs or inspections.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">04</div>
          <h3>Customer-Focused</h3>
          <p>We are committed to clear communication and ensuring your complete satisfaction every step of the way.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2>Schedule Your Pool Inspection</h2>
      <p>Trusted inspection services across Los Angeles. Call us or fill out the form below.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

  <ContactForm />

</Layout>
