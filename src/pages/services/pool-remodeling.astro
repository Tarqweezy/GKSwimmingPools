---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQSection from '../../components/FAQSection.astro';
import { poolReplasteringFAQs } from '../../data/faq-data.js';
---

<Layout
  title="Pool renovation in Santa Clarita | GK Swimming Pools"
  description="Trusted pool contractor for swimming pool renovation across Santa Clarita and LA. Plaster, tile, decking, and full remodels. Free estimates: (818) 804-8204."
>

  <section class="hero">
    <div class="hero__bg">
      <img src="/images/services/pool-remodeling-hero.webp" alt="Remodeled swimming pool with new tile and spa feature" fetchpriority="high" decoding="async" />
    </div>
    <div class="container hero__inner">
      <h1 class="hero__h1">Pool Remodeling · Los Angeles</h1>
      <p class="hero__offer">Swimming Pool Remodeling<br><em>in Los Angeles for 20+ Years</em></p>
      <p class="hero__sub">Transform your backyard with expert pool renovations, from a fresh plaster coat to a complete pool and deck overhaul.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Price</a>
        <a href="tel:8188048204" class="btn btn--outline">Call Us Today</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 760px;">
        <span class="eyebrow">Swimming Pool Renovations in LA</span>
        <p class="lead" style="margin-bottom: 1.5rem;">
          GK Swimming Pools specializes in expert swimming pool renovations and spa remodeling services across Los Angeles. Whether you're looking to update your pool's appearance, upgrade equipment, or completely transform your backyard, our certified team delivers high-quality results.
        </p>
        <p style="color: var(--color-muted);">
          We proudly serve homeowners throughout West LA, Encino, Sherman Oaks, Brentwood, Pacific Palisades, Bel Air, Malibu, Marina Del Rey, and Beverly Hills. With over 20 years as one of the leading pool remodeling companies in LA, our licensed and insured team brings unmatched expertise to every project.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Offer</span>
        <h2>Our Pool Remodeling Services Include</h2>
      </div>
      <ul class="service-list">
        <li>
          <strong>Plaster Resurfacing</strong>
          We apply fresh plaster to your pool or spa for a smooth, clean, and attractive new finish that completely transforms the look of your water.
        </li>
        <li>
          <strong>Pool and Spa Structural Upgrades</strong>
          Our team reinforces and upgrades the shell of your pool or spa, addressing any underlying issues while giving it a fresh, modernized look.
        </li>
        <li>
          <strong>Re-plumbing and Pipe Upgrades</strong>
          We replace outdated or inefficient plumbing lines to improve water flow, energy efficiency, and long-term reliability.
        </li>
        <li>
          <strong>Tile and Waterline Tile Installation</strong>
          A signature element of any pool renovation. We install new tile along the waterline or throughout the pool and spa for a beautiful, custom look.
        </li>
        <li>
          <strong>Pool Deck Remodeling</strong>
          We resurface and redesign pool and spa decks, transforming worn or outdated concrete into stunning new surfaces that elevate your entire outdoor space.
        </li>
        <li>
          <strong>Lighting Upgrades</strong>
          Our team installs modern LED and color lighting systems to enhance ambiance and make nighttime swimming an experience.
        </li>
        <li>
          <strong>Skimmer and Equipment Upgrades</strong>
          As part of a full pool remodel, we replace and upgrade skimmers, pumps, and filtration systems to improve performance and efficiency.
        </li>
        <li>
          <strong>Filter and Circulation System Upgrades</strong>
          We install new, high-efficiency filtration systems to keep your water crystal clear and reduce long-term maintenance demands.
        </li>
        <li>
          <strong>Heater and Energy Efficiency Upgrades</strong>
          Our team replaces older heaters with modern, energy-efficient systems so your pool stays warm while keeping operating costs down.
        </li>
        <li>
          <strong>Spa Jets and Hydrotherapy System Installation</strong>
          We design and install upgraded spa jet systems and hydrotherapy features as part of a comprehensive pool and spa remodeling project.
        </li>
        <li>
          <strong>Automation and Smart System Integration</strong>
          We integrate modern automation systems that let you control your pool lighting, temperature, and equipment from your phone.
        </li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why GK</span>
        <h2>Why Choose GK Swimming Pools for Your Remodel?</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">01</div>
          <h3>Experienced & Reliable</h3>
          <p>With 20+ years as one of the most trusted pool remodeling companies in LA, we deliver professional service tailored to your vision.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">02</div>
          <h3>Design Consultations</h3>
          <p>Before any work begins, we walk you through detailed design options and provide clear project timelines so you know exactly what to expect.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">03</div>
          <h3>Transparent Pricing</h3>
          <p>We offer competitive, upfront pricing with no hidden fees, because quality pool renovations should be an exciting investment, not a stressful one.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">04</div>
          <h3>Customer-Focused</h3>
          <p>We are committed to clear communication and ensuring your complete satisfaction at every stage of the remodeling process.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQSection faqs={poolReplasteringFAQs} heading="Pool Replastering FAQs" />

  <div class="cta-band">
    <div class="container">
      <h2>Ready to Transform Your Pool?</h2>
      <p>Free design consultation. Transparent pricing. Call us or fill out the form to get started.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

  <ContactForm />

</Layout>
