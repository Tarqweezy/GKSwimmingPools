---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Jacuzzi & spa service in Santa Clarita | GK Swimming Pools"
  description="Weekly jacuzzi and spa service across Santa Clarita and the San Fernando Valley. Water balancing, cleaning, and repairs. Call (818) 804-8204."
>

  <section class="hero">
    <div class="hero__bg">
      <img src="/images/services/jacuzzi-service-hero.webp" alt="Illuminated backyard jacuzzi at night" fetchpriority="high" decoding="async" />
    </div>
    <div class="container hero__inner">
      <h1 class="hero__h1">Jacuzzi & Hot Tub Service · Los Angeles</h1>
      <p class="hero__offer">Jacuzzi Maintenance<br><em>and Repairs</em></p>
      <p class="hero__sub">Comprehensive jacuzzi repairs, maintenance, and system checks across Los Angeles. Done properly, by people who know spas.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Price</a>
        <a href="tel:8188048204" class="btn btn--outline">Schedule an Inspection</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 760px;">
        <span class="eyebrow">Jacuzzi Repairs in Southern California</span>
        <p class="lead" style="margin-bottom: 1.5rem;">
          GK Swimming Pools specializes in comprehensive jacuzzi repairs all across Los Angeles. Whether your jacuzzi needs professional repairs, routine maintenance, or a full system check, our certified technicians provide reliable service to keep your spa running smoothly, safely, and efficiently.
        </p>
        <p style="color: var(--color-muted);">
          We proudly serve homeowners throughout West LA, Encino, Sherman Oaks, Brentwood, Pacific Palisades, Bel Air, Malibu, Marina Del Rey, and Beverly Hills. With over 20 years of experience, our licensed and insured technicians bring unmatched expertise to every job.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What's Included</span>
        <h2>Our Jacuzzi Services Include</h2>
      </div>
      <ul class="service-list">
        <li>
          <strong>Structural Inspection</strong>
          Comprehensive examination of the jacuzzi shell for cracks, surface wear, or structural movement that could cause leaks or safety concerns.
        </li>
        <li>
          <strong>Non-Invasive Plumbing Inspection</strong>
          Using advanced, non-invasive techniques to inspect the jacuzzi's plumbing and jet lines for leaks, blockages, or damage, without disturbing your deck.
        </li>
        <li>
          <strong>Equipment Inspection</strong>
          Thorough assessment of all major components: pumps, heaters, filters, and control systems, to ensure your jacuzzi operates efficiently and safely.
        </li>
        <li>
          <strong>Circulation and Filtration System Check</strong>
          Evaluating water flow, filtration, and jet performance to confirm your jacuzzi maintains clear, balanced, and properly circulating water.
        </li>
        <li>
          <strong>Jacuzzi Shell Inspection</strong>
          Detailed review of the fiberglass surfaces for cracks, fading, or erosion that can affect both the look and longevity of your jacuzzi.
        </li>
        <li>
          <strong>Deck and Surrounding Area Inspection</strong>
          Checking the area around your jacuzzi for cracks, drainage issues, or surface wear that could create trip hazards or long-term maintenance problems.
        </li>
        <li>
          <strong>Jets & Drain Inspection</strong>
          Inspecting the condition and operation of jets, drains, and suction fittings to ensure proper water flow, performance, and safety compliance.
        </li>
        <li>
          <strong>Safety Feature Assessment</strong>
          Reviewing covers, electrical grounding, and emergency shut-offs to confirm your jacuzzi meets safety standards and provides peace of mind.
        </li>
        <li>
          <strong>Safety Performance Evaluation</strong>
          Testing temperature control, timers, lighting, and air systems to make sure every feature of your jacuzzi functions reliably.
        </li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why GK</span>
        <h2>Why Choose GK Swimming Pools?</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">01</div>
          <h3>Experienced & Reliable</h3>
          <p>With years of experience, we offer professional and reliable service tailored specifically to the needs of your residential jacuzzi or spa.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">02</div>
          <h3>Comprehensive Reports</h3>
          <p>After each inspection, we provide detailed reports with recommendations for any necessary repairs or maintenance.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">03</div>
          <h3>Transparent Pricing</h3>
          <p>We offer competitive and upfront pricing with no hidden fees for repairs or inspections.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">04</div>
          <h3>Customer-Focused</h3>
          <p>We are committed to clear communication and ensuring your complete satisfaction every step of the way.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2>Get Your Jacuzzi Running Right</h2>
      <p>Trusted jacuzzi service across Los Angeles. Call us or fill out the form below.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

  <ContactForm />

</Layout>
