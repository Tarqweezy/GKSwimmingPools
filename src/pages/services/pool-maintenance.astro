---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Pool cleaning service in Santa Clarita | GK Swimming Pools"
  description="Weekly pool cleaning service for Santa Clarita and the San Fernando Valley. Honest pricing, weekly reports, 20+ years experience. Call (818) 804-8204."
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="/images/services/pool-maintenance-hero.webp" alt="Pool water chemistry testing during a routine maintenance visit" fetchpriority="high" decoding="async" />
    </div>
    <div class="container hero__inner">
      <h1 class="hero__h1">Pool Maintenance · Los Angeles</h1>
      <p class="hero__offer">Crystal Clear Pools<br><em>365 Days a Year</em></p>
      <p class="hero__sub">Expert pool maintenance and spa cleaning across Los Angeles. Weekly reports, transparent pricing, and a technician who cares.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Price</a>
        <a href="tel:8188048204" class="btn btn--outline">Schedule This Week</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div style="max-width: 760px;">
        <span class="eyebrow">About Our Service</span>
        <p class="lead" style="margin-bottom: 1.5rem;">
          GK Swimming Pools specializes in expert pool maintenance and spa cleaning services across Los Angeles. Whether you need routine weekly maintenance or a full-service cleaning, we ensure your water stays crystal clear and your pool is always swim-ready.
        </p>
        <p style="color: var(--color-muted);">
          From surface skimming and vacuuming to chemical balancing and filter care, our certified technicians deliver thorough, high-quality pool maintenance that keeps your pool sparkling, safe, and inviting all year round. We proudly serve homeowners throughout West LA, Encino, Sherman Oaks, Brentwood, Pacific Palisades, Bel Air, Malibu, Marina Del Rey, and Beverly Hills.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What's Included</span>
        <h2>Our Pool Cleaning Services</h2>
      </div>
      <ul class="service-list">
        <li>
          <strong>Surface Skimming / Debris Removal</strong>
          A core part of any maintenance routine. We remove leaves, bugs, and surface debris from your pool or spa.
        </li>
        <li>
          <strong>Wall and Floor Brushing</strong>
          We brush pool and spa walls, steps, and floors to eliminate algae buildup and prevent staining.
        </li>
        <li>
          <strong>Vacuuming</strong>
          Thorough vacuuming of the pool floor to remove dirt, sand, and debris that settle at the bottom.
        </li>
        <li>
          <strong>Tile / Waterline Cleaning</strong>
          Scrubbing tiles and waterlines to remove calcium buildup, oils, and scum for a spotless, polished look.
        </li>
        <li>
          <strong>Chemical Testing / Balancing</strong>
          Testing and adjusting chlorine, pH, alkalinity, and other chemical levels: the #1 rule of pool maintenance.
        </li>
        <li>
          <strong>Filter Cleaning and Maintenance</strong>
          Cleaning and inspecting filters to ensure proper water circulation and filtration for crystal-clear water.
        </li>
        <li>
          <strong>Pump and Skimmer Basket Cleaning</strong>
          Emptying pump and skimmer baskets to maintain optimal water flow and prevent equipment strain.
        </li>
        <li>
          <strong>Algae Treatment and Prevention</strong>
          Targeted treatments that eliminate and prevent algae growth, keeping your pool water healthy and clear.
        </li>
        <li>
          <strong>Shock Treatments</strong>
          Routine shock treatments eliminate bacteria, organic contaminants, and cloudy water.
        </li>
        <li>
          <strong>Seasonal Deep Cleaning</strong>
          Deep cleaning services during opening and closing seasons to prepare your pool for use or the off-season.
        </li>
        <li>
          <strong>Weekly or Biweekly Cleaning Plans</strong>
          Customizable maintenance schedules that keep your pool looking its best all season long.
        </li>
      </ul>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why GK</span>
        <h2>Why Choose GK Pools for Your Residential Pool?</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">01</div>
          <h3>Experienced & Reliable</h3>
          <p>With 20+ years delivering professional LA pool maintenance, we offer reliable service tailored specifically to the needs of your residential pool or spa.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">02</div>
          <h3>Affordable, Transparent Pricing</h3>
          <p>We offer competitive, upfront pricing with no hidden fees, because great pool maintenance shouldn't come with surprises.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">03</div>
          <h3>Customer-Focused Service</h3>
          <p>We are committed to clear communication and ensuring your complete satisfaction at every step of your pool maintenance experience.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <div class="cta-band">
    <div class="container">
      <h2>Ready for a Cleaner Pool?</h2>
      <p>Get booked this week. Free consultation, no contracts, honest pricing.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

  <ContactForm />

</Layout>
