---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';

// FAQPage schema — must mirror the visible FAQ section below
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What types of commercial properties do you service?",
      acceptedAnswer: { "@type": "Answer", text: "We service apartment communities, hotels, and gyms across Los Angeles, the San Fernando Valley, and Santa Clarita. If your property has a shared pool or spa, we can maintain it." },
    },
    {
      "@type": "Question",
      name: "How do commercial reports work?",
      acceptedAnswer: { "@type": "Answer", text: "After every visit we send a detailed report by email: chemical readings, work performed, and anything we flagged. Property managers get consistent documentation without having to chase it down." },
    },
    {
      "@type": "Question",
      name: "How often should a commercial pool be serviced?",
      acceptedAnswer: { "@type": "Answer", text: "It depends on bather load. Most apartment and gym pools need at least weekly service, and heavily used pools often need more. We'll recommend a schedule based on your property's actual usage, not a one-size-fits-all plan." },
    },
    {
      "@type": "Question",
      name: "Do you handle repairs on commercial pools?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. The same repair work we do residentially, cracks, plumbing, equipment, we do for commercial properties, with scheduling that minimizes downtime for your residents or guests." },
    },
  ],
};
---

<Layout
  title="Commercial pool service in Los Angeles | GK Swimming Pools"
  description="Commercial pool service for apartments, hotels, and gyms across Los Angeles. Licensed, reliable, with detailed email reports. Call (818) 804-8204."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="/images/cities/resort-pool-dusk.webp" alt="Commercial resort pool maintained by GK Swimming Pools" fetchpriority="high" decoding="async" />
    </div>
    <div class="container hero__inner">
      <h1 class="hero__h1">Commercial Pool Service · Los Angeles</h1>
      <p class="hero__offer">Commercial Pool Cleaners<br><em>Your Tenants Can Count On</em></p>
      <p class="hero__sub">Reliable commercial pool service for apartment communities, hotels, and gyms across Los Angeles. Consistent schedules, detailed email reports, honest pricing.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Price</a>
        <a href="tel:8188048204" class="btn btn--outline">Schedule This Week</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div style="max-width: 760px;">
        <span class="eyebrow">About Our Commercial Service</span>
        <p class="lead" style="margin-bottom: 1.5rem;">
          GK Swimming Pools provides expert commercial pool service and maintenance for properties throughout Los Angeles, the San Fernando Valley, and Santa Clarita. As experienced commercial pool contractors, we keep shared pools safe, clean, and swim-ready for the residents and guests who count on them.
        </p>
        <p style="color: var(--color-muted);">
          A commercial pool is different from a backyard pool. Higher bather loads, liability considerations, and residents who notice the moment something is off. We service apartment communities, hotels, and gyms with the consistency a shared amenity demands, and every visit is documented in a detailed report delivered straight to your email, so property managers always have a paper trail.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What's Included</span>
        <h2>Our Commercial Pool Services</h2>
      </div>
      <ul class="service-list">
        <li>
          <strong>Routine Cleaning and Maintenance</strong>
          Weekly or multi-visit schedules built around your property's bather load. Skimming, brushing, vacuuming, and tile cleaning on every visit.
        </li>
        <li>
          <strong>Chemical Testing and Balancing</strong>
          Consistent chlorine, pH, and alkalinity management, the foundation of a safe shared pool with heavy daily use.
        </li>
        <li>
          <strong>Equipment Inspection and Upkeep</strong>
          Quick, professional checkups on pumps, filters, heaters, and automation to catch problems before your residents do.
        </li>
        <li>
          <strong>Filter Cleaning</strong>
          Regular filter service to keep circulation strong under commercial bather loads.
        </li>
        <li>
          <strong>Repairs</strong>
          From cracked plaster to failed equipment, the same repair expertise we bring to residential pools, scaled for commercial properties.
        </li>
        <li>
          <strong>Detailed Email Reports</strong>
          After every visit, a written report with chemical readings, work performed, and anything flagged, delivered by email so property managers have documentation on file.
        </li>
      </ul>
    </div>
  </section>

  <!-- PROPERTY TYPES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Who We Serve</span>
        <h2>Properties We Service</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">01</div>
          <h3>Apartment Communities</h3>
          <p>Apartment pool cleaning and repair on a schedule residents can rely on. A clean, working pool is an amenity that keeps tenants happy, and a neglected one generates complaints fast.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">02</div>
          <h3>Hotels</h3>
          <p>Guests judge the whole property by the pool. We keep hotel pools and spas guest-ready every day, with flexible scheduling that works around your peak hours.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">03</div>
          <h3>Gyms & Fitness Centers</h3>
          <p>High daily bather loads demand tighter chemical management than any backyard pool. We service gym pools with the consistency member usage requires.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why GK</span>
        <h2>Why Property Managers Choose GK</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">01</div>
          <h3>Documentation You Can File</h3>
          <p>Every visit produces a detailed email report: chemicals, readings, work performed, issues flagged. When ownership or residents ask, you have the paper trail.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">02</div>
          <h3>Consistent, Reliable Visits</h3>
          <p>A shared pool can't wait for a technician who shows up when he feels like it. We keep the schedule, every week, because your residents notice when we don't.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num" aria-hidden="true">03</div>
          <h3>Transparent Commercial Pricing</h3>
          <p>Upfront pricing with no hidden fees, scaled honestly to your property's size and usage, not inflated because the check comes from a business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Common Questions</span>
        <h2>Commercial Pool Service FAQs</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What types of commercial properties do you service?</summary>
          <p>We service apartment communities, hotels, and gyms across Los Angeles, the San Fernando Valley, and Santa Clarita. If your property has a shared pool or spa, we can maintain it.</p>
        </details>
        <details class="faq-item">
          <summary>How do commercial reports work?</summary>
          <p>After every visit we send a detailed report by email: chemical readings, work performed, and anything we flagged. Property managers get consistent documentation without having to chase it down.</p>
        </details>
        <details class="faq-item">
          <summary>How often should a commercial pool be serviced?</summary>
          <p>It depends on bather load. Most apartment and gym pools need at least weekly service, and heavily used pools often need more. We'll recommend a schedule based on your property's actual usage, not a one-size-fits-all plan.</p>
        </details>
        <details class="faq-item">
          <summary>Do you handle repairs on commercial pools?</summary>
          <p>Yes. The same repair work we do residentially, cracks, plumbing, equipment, we do for commercial properties, with scheduling that minimizes downtime for your residents or guests.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <div class="cta-band">
    <div class="container">
      <h2>Get a Commercial Service Quote</h2>
      <p>Tell us about your property and we'll put together an honest, transparent quote.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

  <ContactForm />

</Layout>
