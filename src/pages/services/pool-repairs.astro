---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Pool repair service in Santa Clarita | GK Swimming Pools"
  description="Fast, reliable pool repairs across Santa Clarita and the San Fernando Valley. Cracks, leaks, pipes, and equipment. Honest pricing. Call (818) 804-8204."
>

  <section class="hero">
    <div class="hero__bg">
      <img src="/images/services/pool-repair-hero.webp" alt="Pool repair technician working on backyard pool equipment" fetchpriority="high" decoding="async" />
    </div>
    <div class="container hero__inner">
      <h1 class="hero__h1">Pool Repairs · Los Angeles</h1>
      <p class="hero__offer">#1 Pool Repair Company<br><em>in Los Angeles for 20+ Years</em></p>
      <p class="hero__sub">Reliable pool and spa leak repairs across Los Angeles. No job too big or too small for our certified LA pool repair team.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Price</a>
        <a href="tel:8188048204" class="btn btn--outline">Repair Your Pool</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 760px;">
        <span class="eyebrow">Reliable Pool & Spa Repair</span>
        <p class="lead" style="margin-bottom: 1.5rem;">
          GK Swimming Pools specializes in expert swimming pool repairs and spa services for pools all across Los Angeles. Whether you're dealing with leaks, equipment failure, or structural damage, our certified LA pool repair team provides efficient, high-quality solutions.
        </p>
        <p style="color: var(--color-muted);">
          We proudly serve homeowners throughout West LA, Encino, Sherman Oaks, Brentwood, Pacific Palisades, Bel Air, Malibu, Marina Del Rey, and Beverly Hills. With over 20 years of experience, our licensed and insured technicians bring unmatched expertise to every job.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Fix</span>
        <h2>Our Pool Repair Services Include</h2>
      </div>
      <ul class="service-list">
        <li>
          <strong>Plaster Repair</strong>
          We fix cracks, chips, and surface damage in pool or spa plaster for a smooth, attractive finish.
        </li>
        <li>
          <strong>Pool & Spa Structure Crack Repairs</strong>
          Our specialists seal cracks in the pool or spa shell to prevent further structural damage and water loss.
        </li>
        <li>
          <strong>Broken Pipe Repairs</strong>
          We fix or replace broken plumbing lines in your pool or spa, a critical repair that prevents leaks and restores proper water flow.
        </li>
        <li>
          <strong>Leak Detection and Repair</strong>
          One of the most in-demand LA pool repairs. We identify and seal leaks in your pool or spa structure and plumbing to prevent costly water loss.
        </li>
        <li>
          <strong>Tile and Grout Repair</strong>
          We fix cracked, loose, or missing tiles and grout to restore your pool's beauty and functionality.
        </li>
        <li>
          <strong>Electrical System Inspection and Repair</strong>
          Our team ensures the electrical systems powering your pool or spa are safe, up to code, and functioning properly.
        </li>
        <li>
          <strong>Skimmer and Pump Basket Replacement</strong>
          We replace worn-out skimmers and pump baskets to improve water circulation and filtration.
        </li>
        <li>
          <strong>Pool & Spa Deck Repair</strong>
          Resurfacing or repairing damaged pool or spa decks, including cracks and weather wear.
        </li>
        <li>
          <strong>Filter Cleaning and Replacement</strong>
          Cleaning or replacing pool or spa filters to maintain crystal-clear water and prevent equipment stress.
        </li>
        <li>
          <strong>Heater Repair and Replacement</strong>
          Our experts repair or replace pool and spa heaters to ensure warm, comfortable water.
        </li>
        <li>
          <strong>Spa Jets and Equipment Repair</strong>
          We inspect and repair malfunctioning spa jets and equipment as part of our full repair and spa service offering.
        </li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why GK</span>
        <h2>Why Choose GK Swimming Pools for Pool Repairs?</h2>
      </div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__num">01</div>
          <h3>Experienced & Reliable</h3>
          <p>With 20+ years of hands-on swimming pool repair experience, we deliver professional, reliable service tailored to your residential pool or spa.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num">02</div>
          <h3>Detailed Inspection Reports</h3>
          <p>After each inspection, we provide detailed reports with recommendations for any necessary repairs or maintenance.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num">03</div>
          <h3>Transparent Pricing</h3>
          <p>We offer competitive, upfront pricing with no hidden fees, because quality swimming pool repairs shouldn't come with surprises.</p>
        </div>
        <div class="why-item">
          <div class="why-item__num">04</div>
          <h3>Customer-Focused</h3>
          <p>We are committed to clear communication and ensuring your complete satisfaction at every stage of your LA pool repair experience.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2>Get Your Pool Repaired Fast</h2>
      <p>Trusted repair services across Los Angeles. Call us today for a free assessment.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

  <ContactForm />

</Layout>
