---
import Layout from '../../layouts/Layout.astro';

// Add new posts here — the cards render automatically
const posts = [
  {
    title: "Swimming Pool Maintenance for Beginners",
    excerpt:
      "Learn the essential chemicals, tools, and routines every pool owner needs to keep their water clean, safe, and looking great year-round.",
    image: "/images/blog/pool-maintenance-hero.webp",
    imageAlt: "Pool cleaning chemicals and tools on a wooden pool deck",
    slug: "/blog/swimming-pool-maintenance-beginners",
    category: "Pool Care",
    readTime: "7 min read",
    date: "July 13, 2025",
  },
  // Paste new post objects below this line
];
---

<Layout
  title="Pool Care Blog | GK Swimming Pools"
  description="Expert pool maintenance tips, guides, and advice from GK Swimming Pools — serving Santa Clarita and the San Fernando Valley."
  canonical="https://www.gkswimmingpools.com/blog"
>

  <!-- HERO -->
  <section class="blog-index-hero">
    <div class="container blog-index-hero__inner">
      <span class="eyebrow">GK Swimming Pools</span>
      <h1>Pool Care Blog</h1>
      <p>Expert tips and guides to help you get the most out of your pool all year long.</p>
    </div>
  </section>

  <!-- GRID -->
  <section class="section">
    <div class="container">
      <div class="blog-index-top">
        <h2>All Articles</h2>
        <span class="blog-index-count">{posts.length} {posts.length === 1 ? "article" : "articles"}</span>
      </div>

      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card">
              <a href={post.slug} class="blog-card__img-wrap">
                <img
                  src={post.image}
                  alt={post.imageAlt}
                  width="640"
                  height="210"
                  loading="lazy"
                  decoding="async"
                />
                <span class="blog-card__category">{post.category}</span>
              </a>
              <div class="blog-card__body">
                <div class="blog-card__meta">
                  <span>{post.date}</span>
                  <span class="blog-card__dot" aria-hidden="true"></span>
                  <span>{post.readTime}</span>
                </div>
                <h3><a href={post.slug}>{post.title}</a></h3>
                <p>{post.excerpt}</p>
                <a href={post.slug} class="blog-card__link">
                  Read Article
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="blog-empty">No articles yet. Check back soon.</p>
      )}
    </div>
  </section>

  <!-- CTA BAND -->
  <div class="cta-band">
    <div class="container">
      <h2>Have a Pool Problem?</h2>
      <p>We are one call away. Serving Santa Clarita and the San Fernando Valley.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>
  </div>

</Layout>

<style>
  /* HERO */
  .blog-index-hero {
    background: linear-gradient(135deg, var(--color-deep) 0%, var(--color-deep-dark) 100%);
    padding: var(--space-24) 0 var(--space-16);
    text-align: center;
  }
  .blog-index-hero__inner .eyebrow {
    color: var(--color-aqua);
    margin-bottom: var(--space-3);
  }
  .blog-index-hero__inner h1 {
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }
  .blog-index-hero__inner p {
    color: rgba(255,255,255,0.75);
    font-size: var(--text-lg);
    margin: 0 auto;
  }

  /* GRID HEADER */
  .blog-index-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .blog-index-top h2 { font-size: var(--text-xl); }
  .blog-index-count {
    font-size: var(--text-sm);
    color: var(--color-muted);
    font-weight: 600;
  }

  /* GRID */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-8);
  }

  /* CARD */
  .blog-card {
    background: var(--color-white);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(8,65,132,0.10);
  }

  .blog-card__img-wrap {
    position: relative;
    height: 210px;
    overflow: hidden;
    display: block;
  }
  .blog-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .blog-card:hover .blog-card__img-wrap img {
    transform: scale(1.04);
  }
  .blog-card__category {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--color-deep);
    color: var(--color-aqua);
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
  }

  .blog-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .blog-card__meta span {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-weight: 600;
  }
  .blog-card__dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-muted);
  }
  .blog-card__body h3 {
    font-size: var(--text-lg);
    color: var(--color-deep);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.3;
  }
  .blog-card__body h3 a { color: inherit; }
  .blog-card__body h3 a:hover { color: var(--color-deep-dark); }
  .blog-card__body p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.7;
    flex: 1;
    margin-bottom: var(--space-4);
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-deep);
    border-bottom: 2px solid var(--color-aqua);
    padding-bottom: 1px;
    width: fit-content;
    transition: color 0.2s;
  }
  .blog-card__link:hover { color: var(--color-deep-dark); }
  .blog-card__link svg { transition: transform 0.2s; }
  .blog-card__link:hover svg { transform: translateX(3px); }

  .blog-empty {
    color: var(--color-muted);
    text-align: center;
    padding: var(--space-16) 0;
  }

  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
