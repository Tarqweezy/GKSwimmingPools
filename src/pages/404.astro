---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | GK Swimming Pools"
  description="The page you're looking for doesn't exist. Find pool maintenance, repairs, inspections, and remodeling services from GK Swimming Pools."
>

  <section class="hero hero--solid">
    <div class="container hero__inner">
      <span class="hero__eyebrow">404</span>
      <h1>We Couldn't Find<br><em>That Page</em></h1>
      <p>The page you're looking for may have moved or no longer exists. Let's get you back on track.</p>
      <div class="hero__actions">
        <a href="/" class="btn btn--primary">Back to Homepage</a>
        <a href="tel:8188048204" class="btn btn--outline">(818) 804-8204</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Where You Might Be Headed</span>
        <h2>Popular Pages</h2>
      </div>
      <div class="service-cards-grid">
        <a href="/services/pool-maintenance" class="service-card">
          <span class="service-card__icon">🏊</span>
          <span class="service-card__title">Pool Maintenance</span>
          <p class="service-card__desc">Weekly service that keeps your water chemistry perfect year-round.</p>
        </a>
        <a href="/services/pool-repairs" class="service-card">
          <span class="service-card__icon">🔧</span>
          <span class="service-card__title">Pool Repairs</span>
          <p class="service-card__desc">Fast, reliable repairs for cracks, leaks, pipes, and equipment.</p>
        </a>
        <a href="/services/pool-inspections" class="service-card">
          <span class="service-card__icon">🔍</span>
          <span class="service-card__title">Pool Inspections</span>
          <p class="service-card__desc">Comprehensive inspections with detailed reports after every visit.</p>
        </a>
        <a href="/services/pool-remodeling" class="service-card">
          <span class="service-card__icon">&#10024;</span>
          <span class="service-card__title">Pool Remodeling</span>
          <p class="service-card__desc">Transform your backyard with new plaster, tile, and decking.</p>
        </a>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2>Still Can't Find What You Need?</h2>
      <p>Reach out directly and we'll point you in the right direction.</p>
      <a href="/contact" class="btn btn--primary">Contact Us</a>
    </div>
  </div>

</Layout>
