---
// src/components/FAQSection.astro
// Renders an FAQ accordion and auto-injects FAQPage schema.
// Usage:
//   import FAQSection from '../components/FAQSection.astro';
//   import { poolCleaningFAQs } from '../data/faq-data.js';
//   <FAQSection faqs={poolCleaningFAQs} heading="Pool Cleaning FAQs" />

interface FAQ {
  question: string;
  answer: string;
}
interface Props {
  faqs: FAQ[];
  heading?: string;
}

const { faqs, heading = "Frequently Asked Questions" } = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<section class="faq section">
  <div class="container">

    <div class="section-header">
      <span class="eyebrow">Got Questions?</span>
      <h2>{heading}</h2>
    </div>

    <div class="faq__list">
      {faqs.map((faq) => (
        <details class="faq__item">
          <summary class="faq__question">
            <span>{faq.question}</span>
            <svg class="faq__chevron" width="20" height="20" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="faq__answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq__footer">
      <p>Still have questions? We are happy to help.</p>
      <a href="tel:8188048204" class="btn btn--primary">(818) 804-8204</a>
    </div>

  </div>
</section>

<style>
  .faq { background: var(--color-mist); }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 820px;
    margin: 0 auto var(--space-12);
  }

  .faq__item {
    background: var(--color-white);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .faq__item[open] {
    border-color: var(--color-aqua);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-6);
    cursor: pointer;
    list-style: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-deep);
    line-height: 1.4;
    user-select: none;
  }
  .faq__question::-webkit-details-marker { display: none; }

  .faq__chevron {
    flex-shrink: 0;
    color: var(--color-aqua);
    transition: transform 0.25s ease;
  }
  .faq__item[open] .faq__chevron {
    transform: rotate(180deg);
  }

  .faq__answer {
    padding: 0 var(--space-6) var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .faq__answer p {
    margin-top: var(--space-4);
    color: var(--color-muted);
    line-height: 1.8;
    font-size: var(--text-base);
    max-width: 68ch;
  }

  .faq__footer {
    text-align: center;
    padding-top: var(--space-4);
  }
  .faq__footer p {
    color: var(--color-muted);
    margin-bottom: var(--space-4);
    max-width: 100%;
  }

  @media (max-width: 640px) {
    .faq__question { padding: var(--space-4); font-size: var(--text-sm); }
    .faq__answer { padding: 0 var(--space-4) var(--space-4); }
  }
</style>
